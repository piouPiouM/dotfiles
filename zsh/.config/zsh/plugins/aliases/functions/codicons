# -------------------------------------------------------------------
# List locally available vscode-codicons
# -------------------------------------------------------------------
# vim:et sts=2 sw=2 ft=zsh

codicons() {
  local doc="file://$(npm -g root)/@vscode/codicons/dist/codicon.html"

  if [[ $CURRENT_OS == "macos" ]] then
    open -a "$BROWSER" $doc
  else
    xdg-open $doc
  fi
}